# DATABASE_URL — choose one:
# Local (no Docker, no Postgres): SQLite — auto-creates tables on startup
DATABASE_URL=sqlite+aiosqlite:///./local.db
# Production / pgvector RAG: Postgres
# DATABASE_URL=postgresql+asyncpg://dev:devpassword@localhost:5432/att_platform

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_STORAGE_CONTAINER=att-platform-files

ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_AUDIENCE=api://att-account-platform

# LLM_MODE: mock | ollama | azure_openai
# Use "mock" for offline development — no external service needed.
LLM_MODE=mock

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Only needed when LLM_MODE=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your_key
LANGCHAIN_PROJECT=att-account-platform

SECRET_KEY=change-me
ENVIRONMENT=development
LOG_LEVEL=INFO
